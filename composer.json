{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "deep-shah/omniporter",
    "type": "library",
    "description": "Unified CSV/Excel Import/Export for Modular Laravel",
    "keywords": [
        "laravel",
        "excel",
        "csv",
        "import",
        "export",
        "queue",
        "spatie",
        "maatwebsite",
        "bulk-import",
        "generic-import"
    ],
    "homepage": "https://github.com/deep-shah/omniporter",
    "license": "MIT",
    "authors": [
        {
            "name": "Deep Shah",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/deep-shah/omniporter/issues",
        "source": "https://github.com/deep-shah/omniporter"
    },
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "maatwebsite/excel": "^3.1",
        "predis/predis": "^3.0",
        "dompdf/dompdf": "^2.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.41",
        "laravel/tinker": "^2.10.1",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.3"
    },
    "autoload": {
        "psr-4": {
            "OmniPorter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": [
            "vendor/bin/phpunit"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "OmniPorter\\OmniPorterServiceProvider"
            ],
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
